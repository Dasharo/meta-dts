From b99293f496ef77b2a01c5e68e430461130cf1ab5 Mon Sep 17 00:00:00 2001
From: Kas User <kas@example.com>
Date: Wed, 11 Feb 2026 10:25:38 +0000
Subject: [PATCH] drivers: ethernet: realtek: backport r8126 support

Adds support for R8126 (e.g. MSI B850 PRO).
Backport v6.8
Backport v6.9 R8126 changes:
 - 3907f1ffc0ecf466d5c04aadc44c4b9203f3ec9a
 - be51ed104ba9929c741afb718ef7198dbcecef94
 - f4d3e595c0000ce39dec7e4799ea42ce42ab6867
 - 5befa3728b855e9f75b29bb0069a1ca7f5bab2f7
Backport v6.12 R8126 changes:
 - 69cb89981c7a181d857b634c0740e914d5df79ea
 - 3b067536daa4842adbf685accf47c899a26367d3

Upstream-Status: Backport v6.8 & r8126 changes

Signed-off-by: Kas User <kas@example.com>
---
 drivers/net/ethernet/realtek/Kconfig          |   7 +
 drivers/net/ethernet/realtek/Makefile         |   3 +-
 drivers/net/ethernet/realtek/r8169.h          |  12 +
 drivers/net/ethernet/realtek/r8169_firmware.c |   3 -
 drivers/net/ethernet/realtek/r8169_leds.c     | 263 ++++++++++++
 drivers/net/ethernet/realtek/r8169_main.c     | 389 +++++++++++-------
 .../net/ethernet/realtek/r8169_phy_config.c   |   8 +
 drivers/net/phy/realtek.c                     |  10 +
 8 files changed, 547 insertions(+), 148 deletions(-)
 create mode 100644 drivers/net/ethernet/realtek/r8169_leds.c

diff --git a/drivers/net/ethernet/realtek/Kconfig b/drivers/net/ethernet/realtek/Kconfig
index 93d9df55b361..03015b665f4e 100644
--- a/drivers/net/ethernet/realtek/Kconfig
+++ b/drivers/net/ethernet/realtek/Kconfig
@@ -113,4 +113,11 @@ config R8169
 	  To compile this driver as a module, choose M here: the module
 	  will be called r8169.  This is recommended.
 
+config R8169_LEDS
+	def_bool R8169 && LEDS_TRIGGER_NETDEV
+	depends on !(R8169=y && LEDS_CLASS=m)
+	help
+	  Optional support for controlling the NIC LED's with the netdev
+	  LED trigger.
+
 endif # NET_VENDOR_REALTEK
